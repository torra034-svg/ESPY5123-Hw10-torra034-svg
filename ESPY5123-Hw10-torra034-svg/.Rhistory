# Chunk 1: setup
library(tidymodels)
library(tidyverse)
library(modeldata)
library(rpart.plot)
library(psych)
set.seed(25)
# Chunk 2: load-data
data(credit_data)
glimpse(credit_data)
# Chunk 3: outcome-exploration
summary(credit_data$Status)
ggplot(credit_data, aes(x = Status, y = Income)) +
geom_col() +
labs(x = "Credit Status",
title = "Credit Status by Income")
ggplot(credit_data, aes(x = Status, fill = Job)) +
geom_bar() +
facet_wrap(~ Job) +
labs(x = "Credit Status",
y = "Count",
fill = "Job Type",
title = "Credit Status by Job Type")
# Chunk 4: tbl-status
#| label: tbl-status
#| tbl-cap: "Status Table"
#| tbl-cap-location: top
credit_data %>%
count(Status) %>%
mutate(Percent = (n / sum(n)) *100)
# Chunk 5: class-balance
ggplot(credit_data, aes(x = Status, fill = Status)) +
geom_bar()
# Chunk 6: split-data
set.seed(123)
data_split <- initial_split(credit_data,
prop = 0.80,
strata = Status)
train_data <- training(data_split)
test_data <- testing(data_split)
# Chunk 7: logistic-spec
log_spec <- logistic_reg() %>%
set_engine("glm") %>%
set_mode("classification")
# Chunk 8: logistic-workflow
log_workflow <- workflow() %>%
add_model(log_spec) %>%
add_formula(Status ~ Income + Job + Debt)
log_workflow
# Chunk 9: logistic-fit
log_fit <- log_workflow %>%
fit(data = credit_data)
log_fit
log_fit(test_data)
# Chunk 1: setup
library(tidymodels)
library(tidyverse)
library(modeldata)
library(rpart.plot)
library(psych)
set.seed(25)
# Chunk 2: load-data
data(credit_data)
glimpse(credit_data)
# Chunk 3: outcome-exploration
summary(credit_data$Status)
ggplot(credit_data, aes(x = Status, fill = Job)) +
geom_bar() +
facet_wrap(~ Job) +
labs(x = "Credit Status",
y = "Count",
fill = "Job Type",
title = "Credit Status by Job Type")
# Chunk 4: tbl-status
#| label: tbl-status
#| tbl-cap: "Status Table"
#| tbl-cap-location: top
credit_data %>%
count(Status) %>%
mutate(Percent = (n / sum(n)) *100)
# Chunk 5: class-balance
ggplot(credit_data, aes(x = Status, fill = Status)) +
geom_bar()
# Chunk 6: split-data
set.seed(123)
data_split <- initial_split(credit_data,
prop = 0.80,
strata = Status)
train_data <- training(data_split)
test_data <- testing(data_split)
# Chunk 7: logistic-spec
log_spec <- logistic_reg() %>%
set_engine("glm") %>%
set_mode("classification")
# Chunk 8: logistic-workflow
log_workflow <- workflow() %>%
add_model(log_spec) %>%
add_formula(Status ~ Income + Job + Debt)
log_workflow
# Chunk 9: logistic-fit
log_fit <- log_workflow %>%
fit(data = credit_data)
log_fit
log_credit_status_preds <- predict(log_fit, new_data = test_data)
log_credit_prob_preds <-predict(log_fit, new_data = test_data, type = "prob")
log_credit_status_preds <- predict(log_fit, new_data = test_data)
log_credit_prob_preds <-predict(log_fit, new_data = test_data, type = "prob")
log_results <- test_data %>%
select(Status) %>%
bind_cols(log_credit_status_preds, log_credit_prob_preds)
log_results
log_results %>%
conf_mat(truth = Status, estimate = .pred_class)
log_results %>%
