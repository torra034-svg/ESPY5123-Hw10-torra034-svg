library(tidymodels)
library(tidyverse)
library(modeldata)
library(rpart.plot)
library(psych)
set.seed(25)
#| label: tbl-status
#| tbl-cap: "Status Table"
#| tbl-cap-location: top
summary(credit_data$Status)
summary(credit_data$Status)
ggplot(credit_data, aes(x = Status, y = Income)) +
geom_col() +
labs(x = "Credit Status",
title = "Credit Status by Income")
ggplot(credit_data, aes(x = Status, fill = Job)) +
geom_bar() +
facet_wrap(~ Job) +
labs(x = "Credit Status",
y = "Count",
fill = "Job Type",
title = "Credit Status by Job Type")
summary(credit_data$Status)
ggplot(credit_data, aes(x = Status, y = Income)) +
geom_col() +
labs(x = "Credit Status",
title = "Credit Status by Income")
ggplot(credit_data, aes(x = Status, fill = Job)) +
geom_bar() +
facet_wrap(~ Job) +
labs(x = "Credit Status",
y = "Count",
fill = "Job Type",
title = "Credit Status by Job Type")
#| label: tbl-status
#| tbl-cap: "Status Table"
#| tbl-cap-location: top
describe(credit_data$Status)
#| label: tbl-status
#| tbl-cap: "Status Table"
#| tbl-cap-location: top
describe(credit_data$Status) %>%
tidy()
#| label: tbl-status
