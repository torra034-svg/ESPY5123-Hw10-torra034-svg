#| tbl-cap-location: top
describe(credit_data$Status)
#| label: tbl-status
#| tbl-cap: "Status Table"
#| tbl-cap-location: top
credit_data %>%
count(Status)
summary(credit_data$Status)
#| label: tbl-status
#| tbl-cap: "Status Table"
#| tbl-cap-location: top
credit_data %>%
count(Status) %>%
tidy()
#| label: tbl-status
#| tbl-cap: "Status Table"
#| tbl-cap-location: top
credit_data %>%
group_by(Status) %>%
summarize(Percent = (n / sum(n)) *100)
#| label: tbl-status
#| tbl-cap: "Status Table"
#| tbl-cap-location: top
credit_data %>%
count(Status) %>%
summarize(Percent = (n / sum(n)) *100)
#| label: tbl-status
#| tbl-cap: "Status Table"
#| tbl-cap-location: top
credit_data %>%
count(Status) %>%
mutate(Percent = (n / sum(n)) *100)
#| label: tbl-status
#| tbl-cap: "Status Table"
#| tbl-cap-location: top
credit_data %>%
count(Status) %>%
mutate(Percent = round((n / sum(n)) *100),2)
#| label: tbl-status
#| tbl-cap: "Status Table"
#| tbl-cap-location: top
credit_data %>%
count(Status) %>%
mutate(Percent = (round(n / sum(n)) *100,2))
#| label: tbl-status
#| tbl-cap: "Status Table"
#| tbl-cap-location: top
credit_data %>%
count(Status) %>%
mutate(Percent = ((n / sum(n)) *100)
#| label: tbl-status
#| tbl-cap: "Status Table"
#| tbl-cap-location: top
credit_data %>%
#| label: tbl-status
#| tbl-cap: "Status Table"
#| tbl-cap-location: top
credit_data %>%
count(Status) %>%
mutate(Percent = (n / sum(n)) *100)
ggplot(credit_data, aes(x = Status, fill = Status)) +
geom_bar()
