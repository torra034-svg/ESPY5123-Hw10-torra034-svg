tidy()
log_results %>%
conf_mat(truth = Status, estimate = .pred_class)
log_results %>%
conf_mat(truth = Status, estimate = .pred_class) %>%
tidy() %>%
ggplot(aes(x = Prediction, y = Truth, fill = n)) +
